<UserControl x:Class="umfg.venda.app.UserControls.ucReceberPedido"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:umfg.venda.app.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1080">

    <Viewbox Stretch="Uniform">
        <Grid Background="#EEF2F7" Height="720" Width="1080">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*"/>
                <ColumnDefinition Width="0.95*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="24,24,12,24" Background="White" CornerRadius="18" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="UMFG - Tela Principal" FontSize="20" FontWeight="Bold" Foreground="#1F2937"/>
                        <TextBlock Text="Produtos do pedido" FontSize="14" Foreground="#6B7280" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="14" Padding="8">
                        <DataGrid ItemsSource="{Binding Pedido.Produtos}" HeadersVisibility="None" AutoGenerateColumns="False" 
                                  GridLinesVisibility="None" CanUserAddRows="False" IsReadOnly="True" Background="Transparent" BorderThickness="0" RowHeight="92">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="68" Height="68" CornerRadius="34" Background="White" BorderBrush="#E5E7EB" BorderThickness="1">
                                                <Ellipse Height="64" Width="64">
                                                    <Ellipse.Fill>
                                                        <ImageBrush ImageSource="{Binding Imagem}" Stretch="UniformToFill"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Referencia}" FontWeight="SemiBold" FontSize="18" Foreground="#111827"/>
                                                <TextBlock Text="{Binding Descricao}" FontSize="14" Foreground="#6B7280" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="R$" FontWeight="Bold" FontSize="12" Foreground="#6B7280" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding Valor, StringFormat=N2}" FontWeight="ExtraBold" FontSize="18" Foreground="#111827" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="12,24,24,24" Background="White" CornerRadius="18" Padding="24">
                <StackPanel>
                    <TextBlock Text="Dados do pagamento" FontSize="24" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Preencha os campos abaixo para concluir." FontSize="13" Foreground="#6B7280" Margin="0,4,0,20"/>

                    <TextBlock Text="Selecione um Cartão" FontSize="16" FontWeight="SemiBold" Foreground="#374151"/>
                    <ComboBox FontSize="16" SelectedIndex="{Binding TipoCartaoSelecionado, Mode=TwoWay}" Margin="0,6,0,14" Padding="8">
                        <ComboBoxItem Content="Selecione um Cartão"/>
                        <ComboBoxItem Content="Cartão de Crédito"/>
                        <ComboBoxItem Content="Cartão de Débito"/>
                    </ComboBox>

                    <TextBlock Text="Número do Cartão (Apenas Números)" FontSize="16" FontWeight="SemiBold" Foreground="#374151"/>
                    <TextBox Text="{Binding NumeroCartao, UpdateSourceTrigger=PropertyChanged}" 
                             PreviewTextInput="ValidarSomenteNumeros" MaxLength="19" FontSize="16" Margin="0,6,0,14" Padding="10"/>

                    <TextBlock Text="Código CVV (Apenas Números)" FontSize="16" FontWeight="SemiBold" Foreground="#374151"/>
                    <TextBox Text="{Binding CVV, UpdateSourceTrigger=PropertyChanged}" 
                             PreviewTextInput="ValidarSomenteNumeros" MaxLength="3" FontSize="16" Margin="0,6,0,14" Padding="10"/>

                    <TextBlock Text="Data Validade (MM/AAAA)" FontSize="16" FontWeight="SemiBold" Foreground="#374151"/>
                    <TextBox Text="{Binding DataValidade, UpdateSourceTrigger=PropertyChanged}" 
                             PreviewTextInput="ValidarSomenteNumeros" MaxLength="7" FontSize="16" Margin="0,6,0,14" Padding="10"/>

                    <TextBlock Text="Nome no Cartão (Apenas Letras)" FontSize="16" FontWeight="SemiBold" Foreground="#374151"/>
                    <TextBox Text="{Binding NomeCartao, UpdateSourceTrigger=PropertyChanged}" 
                             PreviewTextInput="ValidarSomenteLetras" MaxLength="50" FontSize="16" Margin="0,6,0,24" Padding="10"/>

                    <Button Content="Receber" Height="48" FontSize="18" FontWeight="Bold" Background="#22C55E" Foreground="White" 
                            Command="{Binding FinalizarCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Viewbox>
</UserControl>