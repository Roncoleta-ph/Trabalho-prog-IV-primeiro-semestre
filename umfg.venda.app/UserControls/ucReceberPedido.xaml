<UserControl x:Class="umfg.venda.app.UserControls.ucReceberPedido"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:umfg.venda.app.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1080">

    <Viewbox Stretch="Uniform">
        <Grid Background="#EEF2F7" Height="720" Width="1080">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*"/>
                <ColumnDefinition Width="0.95*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="24,24,12,24"
                    Background="White"
                    CornerRadius="18"
                    Padding="18">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="UMFG - Tela Principal"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#1F2937"/>
                        <TextBlock Text="Produtos do pedido"
                                   FontSize="14"
                                   Foreground="#6B7280"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="#F8FAFC"
                            CornerRadius="14"
                            Padding="8">

                        <DataGrid ItemsSource="{Binding Pedido.Produtos}"
                                  HeadersVisibility="None"
                                  AutoGenerateColumns="False"
                                  GridLinesVisibility="None"
                                  CanUserSortColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  Background="#F8FAFC"
                                  BorderThickness="0"
                                  RowBackground="#F8FAFC"
                                  AlternatingRowBackground="#F1F5F9"
                                  RowHeight="92">

                            <DataGrid.Resources>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="8"/>
                                </Style>

                                <Style TargetType="DataGridRow">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Margin" Value="0,4,0,4"/>
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="68"
                                                    Height="68"
                                                    CornerRadius="34"
                                                    Background="White"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    BorderBrush="#E5E7EB"
                                                    BorderThickness="1">
                                                <Ellipse Height="64"
                                                         Width="64"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center">
                                                    <Ellipse.Fill>
                                                        <ImageBrush ImageSource="{Binding Imagem}"
                                                                    Stretch="UniformToFill"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Referencia}"
                                                           FontWeight="SemiBold"
                                                           FontSize="18"
                                                           Foreground="#111827"/>
                                                <TextBlock Text="{Binding Descricao}"
                                                           FontSize="14"
                                                           Foreground="#6B7280"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="R$"
                                                           FontWeight="Bold"
                                                           FontSize="12"
                                                           Foreground="#6B7280"
                                                           HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding Valor}"
                                                           FontWeight="ExtraBold"
                                                           FontSize="18"
                                                           Foreground="#111827"
                                                           HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="12,24,24,24"
                    Background="White"
                    CornerRadius="18"
                    Padding="24">

                <StackPanel>
                    <TextBlock Text="Dados do pagamento"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#111827"/>
                    <TextBlock Text="Preencha os campos abaixo para concluir o recebimento."
                               FontSize="13"
                               Foreground="#6B7280"
                               Margin="0,4,0,20"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="Selecione um Cartão"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#374151"/>
                    <ComboBox FontSize="16"
                              SelectedIndex="{Binding TipoCartaoSelecionado, Mode=TwoWay}"
                              Margin="0,6,0,14"
                              Padding="8">
                        <ComboBoxItem Content="Selecione um Cartão"/>
                        <ComboBoxItem Content="Cartão de Crédito"/>
                        <ComboBoxItem Content="Cartão de Débito"/>
                    </ComboBox>

                    <TextBlock Text="Número do Cartão"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#374151"/>
                    <TextBox Text="{Binding NumeroCartao, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16"
                             Margin="0,6,0,14"
                             Padding="10"
                             BorderBrush="#D1D5DB"
                             BorderThickness="1"
                             Background="#F9FAFB"/>

                    <TextBlock Text="Código CVV"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#374151"/>
                    <TextBox Text="{Binding CVV, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16"
                             Margin="0,6,0,14"
                             Padding="10"
                             MaxLength="3"
                             BorderBrush="#D1D5DB"
                             BorderThickness="1"
                             Background="#F9FAFB"/>

                    <TextBlock Text="Data de Validade (MM/yyyy)"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#374151"/>
                    <TextBox Text="{Binding DataValidade, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16"
                             Margin="0,6,0,14"
                             Padding="10"
                             BorderBrush="#D1D5DB"
                             BorderThickness="1"
                             Background="#F9FAFB"/>

                    <TextBlock Text="Nome no Cartão"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#374151"/>
                    <TextBox Text="{Binding NomeCartao, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16"
                             Margin="0,6,0,24"
                             Padding="10"
                             BorderBrush="#D1D5DB"
                             BorderThickness="1"
                             Background="#F9FAFB"/>

                    <Button Content="Receber"
                            Height="48"
                            FontSize="18"
                            FontWeight="Bold"
                            Background="#22C55E"
                            Foreground="White"
                            BorderThickness="0"
                            Command="{Binding FinalizarCommand}"
                            CommandParameter="{Binding}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Viewbox>
</UserControl>