<UserControl x:Class="umfg.venda.app.UserControls.ucReceberPedido"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:umfg.venda.app.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1080">

    <Viewbox Stretch="Uniform">
        <Grid Background="#EEF2F7" Height="720" Width="1080">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*"/>
                <ColumnDefinition Width="0.95*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="24,24,12,24" Background="White" CornerRadius="18" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="UMFG - Tela Principal" FontSize="20" FontWeight="Bold" Foreground="#1F2937"/>
                        <TextBlock Text="Produtos do pedido" FontSize="14" Foreground="#6B7280" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="14" Padding="8">
                        <DataGrid ItemsSource="{Binding Pedido.Produtos}" HeadersVisibility="None"
                                  AutoGenerateColumns="False" GridLinesVisibility="None"
                                  CanUserAddRows="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0" RowHeight="92">

                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="68" Height="68" CornerRadius="34"
                                                    Background="White" BorderBrush="#E5E7EB" BorderThickness="1">
                                                <Ellipse Height="64" Width="64">
                                                    <Ellipse.Fill>
                                                        <ImageBrush ImageSource="{Binding Imagem}" Stretch="UniformToFill"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Referencia}" FontWeight="SemiBold" FontSize="18"/>
                                                <TextBlock Text="{Binding Descricao}" FontSize="14" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="R$" FontWeight="Bold" FontSize="12"/>
                                                <TextBlock Text="{Binding Valor, StringFormat=N2}" FontWeight="Bold" FontSize="18"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="12,24,24,24" Background="White" CornerRadius="18" Padding="24">
                <StackPanel>

                    <TextBlock Text="Dados do pagamento" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="Preencha os campos abaixo para concluir." FontSize="13" Margin="0,4,0,20"/>

                    <TextBlock Text="Tipo de Cartão *"/>
                    <ComboBox SelectedIndex="{Binding TipoCartaoSelecionado}" Margin="0,6,0,14">
                        <ComboBoxItem Content="Selecione um Cartão"/>
                        <ComboBoxItem Content="Cartão de Crédito"/>
                        <ComboBoxItem Content="Cartão de Débito"/>
                    </ComboBox>

                    <TextBlock Text="Número do Cartão *"/>
                    <TextBox Text="{Binding NumeroCartao}" MaxLength="19" Margin="0,6,0,14"/>

                    <TextBlock Text="Código CVV *"/>
                    <TextBox Text="{Binding CVV}" MaxLength="3" Margin="0,6,0,14"/>

                    <TextBlock Text="Data de Validade * (Mês/Ano)"/>
                    <DatePicker SelectedDate="{Binding DataValidade}">
                        <DatePicker.Resources>
                            <Style TargetType="DatePickerTextBox">
                                <Setter Property="Text">
                                    <Setter.Value>
                                        <Binding Path="SelectedDate"
                                                 RelativeSource="{RelativeSource AncestorType=DatePicker}"
                                                 StringFormat="MM/yyyy"/>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DatePicker.Resources>
                    </DatePicker>

                    <TextBlock Text="Nome no Cartão *"/>
                    <TextBox Text="{Binding NomeCartao}" Margin="0,6,0,24"/>

                    <Button Content="Receber Pagamento"
                            Height="48"
                            Background="#22C55E"
                            Foreground="White"
                            Command="{Binding FinalizarCommand}"
                            CommandParameter="{Binding}"/>

                </StackPanel>
            </Border>

        </Grid>
    </Viewbox>
</UserControl>
